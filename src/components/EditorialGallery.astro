---
interface Props {
  label?: string;
  heading?: string;
  images: {
    src: string;
    alt: string;
    caption?: string;
  }[];
  /** Optional pull quote to embed in the grid */
  pullQuote?: string;
}

const {
  label = "A Curated Gallery",
  heading = "Visual Poetics",
  images,
  pullQuote,
} = Astro.props;
---

<section class="editorial-gallery">
  <div class="container">
    <div class="editorial-gallery__header section-header">
      <h2 class="editorial-gallery__heading">{heading}</h2>
      <span class="label">{label}</span>
    </div>

    <div class="editorial-gallery__grid">
      <!-- Large vertical anchor image -->
      <div class="editorial-gallery__main">
        <img src={images[0].src} alt={images[0].alt} loading="lazy" />
      </div>

      <!-- Right stack -->
      <div class="editorial-gallery__stack">
        <div class="editorial-gallery__top">
          {
            images[1] && (
              <div class="editorial-gallery__cell">
                <img src={images[1].src} alt={images[1].alt} loading="lazy" />
              </div>
            )
          }

          <!-- Pull quote cell -->
          <div class="editorial-gallery__quote-cell">
            {
              pullQuote ? (
                <p>{pullQuote}</p>
              ) : (
                images[2] && (
                  <img src={images[2].src} alt={images[2].alt} loading="lazy" />
                )
              )
            }
          </div>
        </div>

        <!-- Wide bottom image -->
        {
          images[3] && (
            <div class="editorial-gallery__wide">
              <img src={images[3].src} alt={images[3].alt} loading="lazy" />
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .editorial-gallery {
    padding-block: var(--section-gap);
  }

  .editorial-gallery__heading {
    font-family: var(--ff-heading);
    font-style: italic;
    font-weight: var(--fw-regular);
  }

  /* Outer grid: main | stack */
  .editorial-gallery__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: calc(1.5 * var(--spacing));
    height: auto;
  }

  @media (min-width: 48em) {
    .editorial-gallery__grid {
      grid-template-columns: 5fr 7fr;
      height: 680px;
    }
  }

  /* Left tall image */
  .editorial-gallery__main {
    overflow: hidden;
    height: 380px;
  }

  @media (min-width: 48em) {
    .editorial-gallery__main {
      height: 100%;
    }
  }

  .editorial-gallery__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(15%);
    transition:
      transform var(--transition-slow),
      filter var(--transition-slow);
  }

  .editorial-gallery__main:hover img {
    transform: scale(1.04);
    filter: grayscale(0%);
  }

  /* Right stack */
  .editorial-gallery__stack {
    display: flex;
    flex-direction: column;
    gap: calc(1.5 * var(--spacing));
  }

  @media (min-width: 48em) {
    .editorial-gallery__stack {
      height: 100%;
    }
  }

  /* Top row: two cells side by side */
  .editorial-gallery__top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: calc(1.5 * var(--spacing));
    flex: 1;
  }

  .editorial-gallery__cell {
    overflow: hidden;
  }

  .editorial-gallery__cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Pull quote cell */
  .editorial-gallery__quote-cell {
    background-color: var(--bg-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(2 * var(--spacing));
    overflow: hidden;
  }

  .editorial-gallery__quote-cell p {
    font-family: var(--ff-heading);
    font-style: italic;
    font-size: var(--fs-h3);
    color: var(--txt-muted);
    line-height: 1.5;
    text-align: center;
    max-width: 100%;
  }

  .editorial-gallery__quote-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Wide bottom image */
  .editorial-gallery__wide {
    overflow: hidden;
    flex: 1;
    min-height: 160px;
  }

  .editorial-gallery__wide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
