---
import PackageCard from "./PackageCard.astro";

const packages = [
  {
    image: "/images/package-date.jpg",
    imageAlt: "Intimate picnic setup for two",
    price: "Starting at $250",
    title: "Basic Picnic",
    body: "An intimate alfresco setting designed for connection, featuring soft textiles and seasonal floral accents.",
    includes: [
      "2 Hours of Curated Dining",
      "Artisanal Grazing Board",
      "Chilled Refreshments",
    ],
    featured: false,
  },
  {
    image:
      "https://plus.unsplash.com/premium_photo-1674197235634-c2c4799d0714?q=80&w=988&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
    imageAlt: "Luxury proposal setup",
    price: "Starting at $450",
    title: "Luxury Setup",
    body: "A masterfully orchestrated scene for life's most significant milestones. Refined, romantic, and camera-ready.",
    includes: [
      "Signature Floral Artistry",
      "Premium Tablescape Design",
      "Secret Event Coordination",
    ],
    featured: true,
  },
  {
    image: "/images/package-group.jpg",
    imageAlt: "Long table event setup",
    price: "Starting at $600",
    title: "Special Event",
    body: "Elevated group dining for your inner circle. A grand long-table aesthetic for birthdays and bridal celebrations.",
    includes: [
      "Seating for 6–12 Guests",
      "Vintage Plate Styling",
      "Custom Stationery & Menus",
    ],
    featured: false,
  },
];
---

<section class="packages" id="content">
  <div class="container">
    <div class="packages__header section-header">
      <h2 class="packages__heading">Curated Packages</h2>
      <p
        class="packages__sub label"
        style="color: var(--clr-secondary); font-style: italic; font-family: var(--ff-heading);"
      >
        Tailored to the occasion
      </p>
    </div>

    <div class="packages__grid">
      {
        packages.map((pkg, i) => (
          <div
            class:list={[
              "packages__item",
              { "packages__item--raised": i === 1 },
            ]}
          >
            <PackageCard {...pkg} />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .packages__header {
    margin-bottom: calc(4 * var(--spacing));
  }

  .packages {
    background-color: var(--bg-surface);
    padding-block: var(--section-gap);
  }

  .packages__heading {
    font-family: var(--ff-heading);
    font-weight: var(--fw-regular);
  }

  .packages__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: calc(3 * var(--spacing));
  }

  @media (min-width: 48em) {
    .packages__grid {
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }

    /* Middle card raised up */
    .packages__item--raised {
      margin-top: calc(-3 * var(--spacing));
    }
  }
</style>
