---
import { getCollection } from "astro:content";
import PackageCard from "./PackageCard.astro";

const allPackages = await getCollection("pricePackages");
const packages = allPackages.sort((a, b) => a.data.order - b.data.order);
---

<section class="packages" id="content">
  <div class="container">
    <div class="packages__header section-header">
      <h2 class="packages__heading">Curated Packages</h2>
      <p
        class="packages__sub label"
        style="color: var(--clr-secondary); font-style: italic; font-family: var(--ff-heading);"
      >
        Tailored to the occasion
      </p>
    </div>
    <div class="packages__grid">
      {packages.map((pkg) => <PackageCard {...pkg.data} />)}
    </div>
  </div>
</section>

<!-- your existing <style> block unchanged -->

<style>
  .packages__header {
    margin-bottom: calc(4 * var(--spacing));
  }
  .packages {
    background-color: var(--bg-surface);
    padding-block: var(--section-gap);
  }
  .packages__heading {
    font-family: var(--ff-heading);
    font-weight: var(--fw-regular);
  }
  .packages__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: calc(3 * var(--spacing));
  }
  @media (min-width: 48em) {
    .packages__grid {
      grid-template-columns: repeat(2, 1fr);
      align-items: start;
    }
  }
  @media (min-width: 72em) {
    .packages__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
