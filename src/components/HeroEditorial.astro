---
interface Props {
  label: string;
  heading: string;
  body: string;
  image: string;
  imageAlt: string;
  /** Flip image to the left, text to the right */
  flip?: boolean;
  compact?: boolean;
}

const {
  label,
  heading,
  body,
  image,
  imageAlt,
  flip = false,
  compact = false,
} = Astro.props;
---

<section class:list={["hero-editorial", { "hero-editorial--flip": flip }]}>
  <div class="hero-editorial__inner container">
    <div class="hero-editorial__text">
      <span class="label">{label}</span>
      <h1 class="hero-editorial__heading" set:html={heading} />
      <p class="hero-editorial__body">{body}</p>
    </div>

    <div
      class:list={[
        "hero-editorial__media",
        { "hero-editorial__media--compact": compact },
      ]}
    >
      <img src={image} alt={imageAlt} class="hero-editorial__img" />
    </div>
  </div>
</section>

<style>
  .hero-editorial {
    padding-top: calc(var(--nav-height) + var(--section-gap));
    padding-bottom: var(--section-gap);
  }

  .hero-editorial__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: calc(3 * var(--spacing));
    align-items: end;
  }

  @media (min-width: 48em) {
    .hero-editorial__inner {
      grid-template-columns: 1fr 1fr;
    }

    .hero-editorial--flip .hero-editorial__text {
      order: 2;
    }
    .hero-editorial--flip .hero-editorial__media {
      order: 1;
    }
  }

  @media (min-width: 64em) {
    .hero-editorial__inner {
      grid-template-columns: 5fr 7fr;
    }
  }

  /* Text side */
  .hero-editorial__text {
    display: flex;
    flex-direction: column;
    gap: calc(1.5 * var(--spacing));
  }

  .hero-editorial__heading {
    font-family: var(--ff-heading);
    font-weight: var(--fw-regular);
    font-size: clamp(2.25rem, 5vw, var(--fs-hero));
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--txt-main);
  }

  .hero-editorial__body {
    font-size: var(--fs-body);
    color: var(--txt-muted);
    line-height: 1.7;
    max-width: 48ch;
  }

  /* Image side */
  .hero-editorial__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .hero-editorial__media--compact {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .hero-editorial__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow);
  }

  .hero-editorial__media:hover .hero-editorial__img {
    transform: scale(1.03);
  }
</style>
