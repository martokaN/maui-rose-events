---
import { Image } from "astro:assets";

interface Props {
  label?: string;
  heading?: string;
  imageSrc: string;
  imageAlt: string;
  /** Reverse layout: image on right, form on left? Default false (image left, form right) */
  reverse?: boolean;
  /** Form action endpoint */
  action?: string;
  /** Success message */
  successMessage?: string;
}

const {
  label = "Get in Touch",
  heading = "Let's Create Something Beautiful",
  imageSrc,
  imageAlt,
  reverse = false,
  action = "/api/contact",
  successMessage = "Thank you — we'll be in touch within 48 hours.",
} = Astro.props;
---

<section class="contact-form-with-image padding-block-lg">
  <div class="container">
    <div class="contact-form-with-image__inner even-columns">
      <div
        class="contact-form-with-image__media"
        style={reverse ? "order: 2" : "order: 1"}
      >
        <Image
          src={imageSrc}
          alt={imageAlt}
          width={600}
          height={800}
          loading="lazy"
          decoding="async"
          class="contact-form-with-image__img"
        />
      </div>
      <div
        class="contact-form-with-image__form"
        style={reverse ? "order: 1" : "order: 2"}
      >
        <div class="contact-form-with-image__header">
          {label && <span class="label">{label}</span>}
          <h2 class="contact-form-with-image__heading serif">{heading}</h2>
        </div>

        <form class="contact-form" action={action} method="POST" novalidate>
          <div class="contact-form__grid">
            <div class="form-field">
              <label for="name">Your Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Full name"
                autocomplete="name"
              />
            </div>
            <div class="form-field">
              <label for="email">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="hello@example.com"
                autocomplete="email"
              />
            </div>
            <div class="form-field form-field--full">
              <label for="event-type">Event Type</label>
              <select id="event-type" name="event_type" required>
                <option value="" disabled selected>Select an option</option>
                <option value="picnic">Picnic Experience</option>
                <option value="wedding">Wedding Celebration</option>
                <option value="proposal">Proposal Setup</option>
                <option value="party">Garden Party</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-field">
              <label for="guests">Number of Guests</label>
              <input
                type="number"
                id="guests"
                name="guests"
                min="1"
                max="500"
                placeholder="e.g. 12"
              />
            </div>
            <div class="form-field">
              <label for="date">Preferred Date</label>
              <input type="date" id="date" name="date" />
            </div>
            <div class="form-field form-field--full">
              <label for="message">Share Your Vision</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                placeholder="Tell us about the atmosphere you wish to create..."
              ></textarea>
            </div>
          </div>

          <div class="contact-form__footer">
            <button type="submit" class="btn btn-primary contact-form__submit">
              Send Inquiry
              <span class="contact-form__arrow" aria-hidden="true">→</span>
            </button>
            <p class="contact-form__privacy label">
              By booking, you agree to our <a href="/policy"
                >booking & cancellation policy.</a
              >
            </p>
          </div>

          <p
            class="contact-form__success"
            id="form-success"
            aria-live="polite"
            hidden
          >
            {successMessage}
          </p>
          <p
            class="contact-form__error"
            id="form-error"
            aria-live="polite"
            hidden
          >
            Something went wrong. Please try again or email us directly.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-form-with-image__inner {
    align-items: center;
    gap: calc(4 * var(--spacing));
  }

  @media (min-width: 48em) {
    .contact-form-with-image__inner {
      grid-auto-flow: column;
      grid-auto-columns: 1fr;
    }
  }

  .contact-form-with-image__media {
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .contact-form-with-image__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow);
  }

  .contact-form-with-image__img:hover {
    transform: scale(1.02);
  }

  .contact-form-with-image__header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: calc(3 * var(--spacing));
  }

  .contact-form-with-image__heading {
    font-size: var(--fs-h2);
    line-height: 1.1;
    color: var(--txt-main);
  }

  /* Form styling */
  .contact-form__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: calc(2 * var(--spacing));
  }

  @media (min-width: 48em) {
    .contact-form__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-field--full {
    grid-column: 1 / -1;
  }

  .form-field label {
    font-size: var(--fs-label);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--clr-secondary);
    margin-bottom: 0.5rem;
    display: block;
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    background-color: var(--bg-surface);
    border: none;
    border-bottom: 1px solid var(--clr-border);
    padding: 0.875rem 0;
    font-family: var(--ff-body);
    font-size: var(--fs-body);
    color: var(--txt-main);
    transition: all var(--transition-fast);
    outline: none;
    appearance: none;
    width: 100%;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    border-bottom-color: var(--clr-primary);
    background-color: var(--bg-surface-alt);
  }

  .form-field textarea {
    resize: none;
  }

  /* Submit row */
  .contact-form__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing);
    margin-top: calc(3 * var(--spacing));
    text-align: center;
  }

  .contact-form__submit {
    width: 100%;
    justify-content: center;
  }

  .contact-form__arrow {
    display: inline-block;
    transition: translate var(--transition-fast);
  }

  .contact-form__submit:hover .contact-form__arrow {
    translate: 4px 0;
  }

  .contact-form__privacy {
    color: var(--txt-light);
    max-width: none;
  }

  .contact-form__privacy a {
    color: var(--txt-main);
    text-decoration: underline;
    text-decoration-color: var(--clr-border);
    text-underline-offset: 3px;
    transition:
      text-decoration-color var(--transition-fast),
      color var(--transition-fast);
  }

  .contact-form__privacy a:hover {
    color: var(--clr-primary);
    text-decoration-color: var(--clr-primary);
  }

  /* Status messages */
  .contact-form__success {
    margin-top: calc(2 * var(--spacing));
    text-align: center;
    color: var(--clr-primary);
    font-size: var(--fs-body);
  }

  .contact-form__error {
    margin-top: calc(2 * var(--spacing));
    text-align: center;
    color: #983030;
    font-size: var(--fs-body);
  }
</style>

