---
import { Image } from "astro:assets";

interface Props {
  quote: string;
  author: string;
  role?: string;
  /** Optional avatar image source */
  avatarSrc?: string;
  avatarAlt?: string;
}

const { quote, author, role, avatarSrc, avatarAlt } = Astro.props;
---

<section class="testimonial padding-block-lg">
  <div class="container container--narrow">
    <blockquote class="testimonial__quote pull-quote">
      {quote}
    </blockquote>
    <div class="testimonial__author">
      {avatarSrc && (
        <div class="testimonial__avatar">
          <Image
            src={avatarSrc}
            alt={avatarAlt || `Portrait of ${author}`}
            width={64}
            height={64}
            loading="lazy"
            decoding="async"
            class="testimonial__avatar-img"
          />
        </div>
      )}
      <div class="testimonial__details">
        <cite class="testimonial__name">{author}</cite>
        {role && <span class="testimonial__role label">{role}</span>}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial {
    background-color: var(--bg-surface);
    text-align: center;
  }

  .testimonial__quote {
    margin-inline: auto;
    margin-bottom: calc(2 * var(--spacing));
  }

  .testimonial__author {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: calc(1 * var(--spacing));
  }

  @media (min-width: 48em) {
    .testimonial__author {
      flex-direction: row;
      justify-content: center;
    }
  }

  .testimonial__avatar {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .testimonial__avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .testimonial__details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .testimonial__name {
    font-family: var(--ff-heading);
    font-style: normal;
    font-size: var(--fs-h3);
    color: var(--txt-main);
  }

  .testimonial__role {
    color: var(--txt-light);
    font-size: var(--fs-small);
  }
</style>