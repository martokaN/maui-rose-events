---
import { Icon } from "astro-icon/components";

interface Props {
  icon: string; /** Lucide icon name e.g. "lucide:heart" */
  title: string;
  body: string;
}
const { icon, title, body } = Astro.props;
---

<article class="service-card">
  <Icon name={icon} class="service-card__icon" aria-hidden="true" />
  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__body">{body}</p>
</article>
<style>
  .service-card {
    display: flex;
    flex-direction: column;
    gap: calc(1.25 * var(--spacing));
  }
  .service-card__icon {
    display: block;
    width: 2rem;
    height: 2rem;
    color: var(--clr-primary);
  }
  .service-card__title {
    font-family: var(--ff-heading);
    font-style: italic;
    font-weight: var(--fw-regular);
    font-size: var(--fs-h3);
    color: var(--txt-main);
  }
  .service-card__body {
    font-size: var(--fs-body);
    color: var(--txt-muted);
    line-height: 1.7;
    max-width: 100%;
  }
</style>
