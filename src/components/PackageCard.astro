---
interface Props {
  image: string;
  imageAlt: string;
  price: string;
  title: string;
  body: string;
  includes: string[];
  /** Makes button filled (use for featured/middle card) */
  featured?: boolean;
  href?: string;
}

const {
  image,
  imageAlt,
  price,
  title,
  body,
  includes,
  featured = false,
  href = "/contact",
} = Astro.props;
---

<article class="package-card">
  <div class="package-card__media">
    <img src={image} alt={imageAlt} class="package-card__img" />
    <span class="badge package-card__price">{price}</span>
  </div>

  <div class="package-card__body">
    <h3 class="package-card__title">{title}</h3>
    <p class="package-card__desc">{body}</p>

    <ul class="package-card__includes" role="list">
      {
        includes.map((item) => (
          <li class="package-card__include">
            <span class="package-card__check" aria-hidden="true" />
            {item}
          </li>
        ))
      }
    </ul>

    <a
      href={href}
      class:list={[
        "btn",
        "package-card__cta",
        featured ? "btn-primary" : "btn-outline",
      ]}
    >
      Book Now
    </a>
  </div>
</article>

<style>
  .package-card {
    display: flex;
    flex-direction: column;
  }

  /* Image */
  .package-card__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .package-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow);
  }

  .package-card:hover .package-card__img {
    transform: scale(1.05);
  }

  .package-card__price {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
  }

  /* Body */
  .package-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding-top: calc(2 * var(--spacing));
    gap: calc(1.25 * var(--spacing));
  }

  .package-card__title {
    font-family: var(--ff-heading);
    font-style: italic;
    font-weight: var(--fw-regular);
    font-size: var(--fs-h3);
    color: var(--txt-main);
  }

  .package-card__desc {
    font-size: var(--fs-small);
    color: var(--txt-muted);
    line-height: 1.7;
    max-width: 100%;
  }

  /* Includes list */
  .package-card__includes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .package-card__include {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: var(--fs-label);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--txt-muted);
  }

  /* Custom checkmark using pseudo element */
  .package-card__check {
    display: block;
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    border: 1px solid var(--clr-border);
    position: relative;
  }

  .package-card__check::after {
    content: "";
    position: absolute;
    inset: 2px;
    background-color: var(--clr-primary);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .package-card:hover .package-card__check::after {
    opacity: 1;
  }

  .package-card__cta {
    width: 100%;
    justify-content: center;
    margin-top: auto;
  }
</style>
