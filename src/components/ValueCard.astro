---
interface Props {
  icon: string;
  title: string;
  body: string;
}

const { icon, title, body } = Astro.props;
---

<article class="value-card">
  <span class="value-card__icon material-symbols-outlined" aria-hidden="true">
    {icon}
  </span>
  <div>
    <h3 class="value-card__title">{title}</h3>
    <p class="value-card__body">{body}</p>
  </div>
</article>

<style>
  .value-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: calc(2 * var(--spacing));
    background-color: var(--bg-main);
    border: 1px solid var(--clr-border);
    padding: calc(2.5 * var(--spacing));
    aspect-ratio: 1;
    transition:
      border-color var(--transition-slow),
      background-color var(--transition-slow);
  }

  .value-card:hover {
    border-color: var(--clr-secondary);
    background-color: #fff;
  }

  .value-card__icon {
    font-size: 2rem;
    color: var(--clr-primary);
    font-variation-settings:
      "FILL" 0,
      "wght" 300,
      "GRAD" 0,
      "opsz" 24;
  }

  .value-card__title {
    font-family: var(--ff-heading);
    font-style: italic;
    font-weight: var(--fw-regular);
    font-size: var(--fs-h3);
    color: var(--txt-main);
    margin-bottom: 0.5rem;
  }

  .value-card__body {
    font-size: var(--fs-small);
    color: var(--txt-muted);
    line-height: 1.7;
    max-width: 100%;
  }
</style>
