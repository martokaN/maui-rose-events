---
import ServiceCard from "./ServiceCard.astro";

interface Props {
  label?: string;
  heading?: string;
}

const { label = "What we offer", heading = "Every detail, considered" } =
  Astro.props;

const services = [
  {
    icon: "lucide:heart",
    title: "Small Weddings",
    body: "We specialize in creating beautifully styled small weddings that feel intimate, elegant, and truly personal. Whether you're dreaming of a romantic beach ceremony or a simple, stylish celebration, we focus on every detail to bring your vision to life.",
  },
  {
    icon: "lucide:list-checks",
    title: "How We Work",
    body: "We start by understanding your vision, style, and preferences. Then we create a customized setup just for you. On the day of your wedding, we take care of the full setup and styling, making the experience stress-free and seamless.",
  },
  {
    icon: "lucide:contact",
    title: "Contact Us",
    body: "To start planning your special day, simply reach out to us via Instagram, email, or our contact form. Tell us your date, location, and idea, and we'll take care of the rest.",
  },
];
---

<!-- Material Symbols font — only loaded once if not already in Layout -->
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
/>

<section class="services">
  <div class="container">
    <div class="services__header">
      <span class="label">{label}</span>
      <h2 class="services__heading">{heading}</h2>
    </div>

    <div class="services__grid">
      {services.map((service) => <ServiceCard {...service} />)}
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--bg-surface);
    padding-block: var(--section-gap);
  }

  .services__header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: calc(3 * var(--spacing));
  }

  .services__heading {
    font-family: var(--ff-heading);
    font-weight: var(--fw-regular);
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: calc(3 * var(--spacing));
  }

  @media (min-width: 48em) {
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
