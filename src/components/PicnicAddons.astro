---
interface Props {
  label?: string;
  heading?: string;
}

const { label = "Elevate Your Stay", heading = "Optional Add-ons" } =
  Astro.props;

const addons = [
  { name: "Lei greeting", note: "Hawaiian welcome", price: "$45 / person" },
  { name: "Premium charcuterie board", note: "Large / themed", price: "$120" },
  { name: "Cake or mini dessert set", note: "", price: "$90" },
  { name: "Bubbles", note: "", price: "30$" },
  { name: "Fresh flower upgrade", note: "", price: "$75+" },
  {
    name: "Professional photographer",
    note: "30 min / 1 hour",
    price: "$350 / $650",
  },
  { name: "Balloon decor", note: "", price: "$150" },
  { name: "Painting picnic", note: "Canvas + paint", price: "$25/ person" },
  {
    name: "Movie picnic setup",
    note: "Projector + screen (Private property only)",
    price: "$150",
  },
  { name: "Fresh coconut", note: "", price: "$15" },
  { name: "Local Fruit Platter", note: "", price: "$45" },
  { name: "Large Charcuterie", note: "2–4 guests", price: "$150" },
  { name: "Gourmet pastry Basket", note: "", price: "$45" },
  { name: "Polaroid Package", note: "Camera + 10 films", price: "$45" },
  { name: "Private Lei Making Lesson", note: "", price: "$150" },
];
---

<section class="addons">
  <div class="container--narrow">
    <div class="section-header">
      <h2 class="fs-h2">{heading}</h2>
      <span
        class="label"
        style="font-family: var(--ff-heading); font-style: italic;"
        >{label}</span
      >
    </div>

    <ul class="addons__grid" role="list">
      {
        addons.map((addon) => (
          <li class="addons__item">
            <div class="addons__info">
              <span class="addons__name">{addon.name}</span>
              {addon.note && <span class="addons__note">— {addon.note}</span>}
            </div>
            <span class="addons__price">{addon.price}</span>
          </li>
        ))
      }
    </ul>

    <!-- <p class="addons__footer-text label text-center">
      All add-ons must be requested at least 72 hours in advance.
    </p> -->
  </div>
</section>

<style>
  .addons {
    padding-bottom: var(--section-gap);
    background-color: var(--bg-main);
  }

  /* Shared header style from your global/pricing */
  .addons .section-header {
    margin-bottom: calc(2 * var(--spacing));
  }

  .addons__grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 48em) {
    .addons__grid {
      grid-template-columns: 1fr 1fr;
      column-gap: calc(4 * var(--spacing));
    }
  }

  .addons__price {
    font-family: var(--ff-heading);
    font-size: var(--fs-small);
    color: var(--txt-muted);
    white-space: nowrap; /* Keeps the price on one line */
    margin-left: 1rem;
  }

  .addons__item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-block: 1.25rem;
    border-bottom: 1px solid var(--clr-border);
    transition: padding-left var(--transition-fast);
  }

  .addons__item:hover {
    padding-left: 0.5rem;
  }

  .addons__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .addons__name {
    font-family: var(--ff-heading);
    font-size: var(--fs-body);
    color: var(--txt-main);
  }

  .addons__note {
    font-family: var(--ff-body);
    font-size: var(--fs-label);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--txt-light);
  }

  .addons__footer-text {
    display: block;
    margin-top: calc(2 * var(--spacing));
    font-style: italic;
    max-width: 100%;
  }
</style>
