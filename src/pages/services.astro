<style>
  /* Hero */
  .svc-hero {
    padding-top: calc(var(--nav-height) + var(--section-gap));
    padding-bottom: var(--section-gap);
  }

  .svc-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: calc(4 * var(--spacing));
    align-items: center;
  }

  @media (min-width: 48em) {
    .svc-hero__inner {
      grid-template-columns: 5fr 4fr;
    }
  }

  .svc-hero__text {
    display: flex;
    flex-direction: column;
    gap: calc(1.5 * var(--spacing));
  }

  .svc-hero__heading {
    font-family: var(--ff-heading);
    font-weight: var(--fw-regular);
    font-size: clamp(2.25rem, 4.5vw, var(--fs-hero));
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--txt-main);
  }

  .svc-hero__heading em {
    font-style: italic;
  }

  .svc-hero__body {
    font-size: var(--fs-body);
    color: var(--txt-muted);
    line-height: 1.7;
    max-width: 52ch;
  }

  /* Staggered two-image column */
  .svc-hero__media {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: calc(1.5 * var(--spacing));
    align-items: start;
  }

  .svc-hero__img {
    overflow: hidden;
  }

  .svc-hero__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow);
  }

  .svc-hero__img:hover img {
    transform: scale(1.04);
  }

  .svc-hero__img--top {
    aspect-ratio: 3 / 4;
  }

  /* Push the second image down for a staggered look */
  .svc-hero__img--bottom {
    aspect-ratio: 3 / 4;
    margin-top: calc(3 * var(--spacing));
  }
</style>
