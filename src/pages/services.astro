---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import CtaBanner from "../components/CtaBanner.astro";
import HeroEditorial from "../components/HeroEditorial.astro";
import PackagesEditorial from "../components/PackagesEditorial.svelte";

const rawPackages = await getCollection("pricePackages");
const rawAddons = await getCollection("addons");

// 1. Map data and process images through Astro's pipeline
const packages = await Promise.all(
  rawPackages.map(async (pkg) => {
    // Generate the correct public URL for the image
    const optimizedImage = await getImage({ src: pkg.data.image });

    return {
      id: pkg.id,
      basePrice: Number(pkg.data.price.replace(/[^0-9.-]+/g, "")),
      featured: false,
      imageSrc: optimizedImage.src,
      ...pkg.data,
    };
  }),
);

// 2. Sort the packages
packages.sort((a, b) => a.order - b.order);

// 3. Map addons
const globalAddons = rawAddons.flatMap((doc) =>
  doc.data.map((addon) => ({
    id: addon.name.toLowerCase().replace(/\s+/g, "-"),
    amount: Number(addon.price.replace(/[^0-9.-]+/g, "")),
    ...addon,
  })),
);

import image from "../assets/services/3913.png";
---

<Layout
  title="Services"
  description="Luxury picnic experiences and bespoke wedding styling from The Garden Table."
>
  <HeroEditorial
    label="Picnics & Weddings"
    heading="Every gathering deserves to be <em>unforgettable.</em>"
    body="Whether an intimiate picnic for two or a grand wedding celebration, we bring the same obsessive attention to detail to every event we touch."
    image={image}
    imageAlt="Elegant outdoor wedding table with organic florals and candlelight"
    compact={true}
  />

  <PackagesEditorial {packages} {globalAddons} client:load />

  <CtaBanner />
</Layout>
