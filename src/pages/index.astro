---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import InstagramGrid from "../components/InstagramGrid.astro";
import CtaBanner from "../components/CtaBanner.astro";
import ServicesGrid from "../components/ServicesGrid.astro";

import img2972 from "../assets/instagram/2972.jpg";
import img3912 from "../assets/instagram/3912.png";
import img3984 from "../assets/instagram/3984.jpg";
import imgBKR from "../assets/instagram/BKR03136-Edit.jpg";
import image1 from "../assets/instagram/image1.jpg";
import image2 from "../assets/instagram/image2.jpg";

const instagramPhotos = [
  { src: imgBKR, alt: "" },
  { src: image1, alt: "" },
  { src: image2, alt: "" },
  { src: img3984, alt: "" },
  { src: img3912, alt: "" },
  { src: img2972, alt: "" },
];
---

<Layout
  title="Home"
  description="The Garden Table — bespoke picnic and wedding styling experiences curated for your story."
>
  <Hero
    tagline="Denifed by detail"
    heading="The Art of the <em>Outdoors</em> Dining"
    image="https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=1920&q=80"
    imageAlt="Long outdoor wedding reception table set beneath a canopy of trees at golden hour"
  />

  <HowItWorks />

  <ServicesGrid />

  <InstagramGrid
    heading="Follow our Instagram"
    handle="@MauiRoseEvents"
    profileUrl="https://instagram.com"
  />

  <CtaBanner />
</Layout>
